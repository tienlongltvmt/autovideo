# URL của cobalt API instance (self-host bằng docker compose trong repo này)
COBALT_API_URL=http://localhost:9000

# API key nếu instance yêu cầu xác thực (để trống nếu không dùng)
COBALT_API_KEY=

# Số video tải đồng thời tối đa
CONCURRENCY=3

# Thư mục lưu file tải về
DOWNLOAD_DIR=./downloads

# Thư mục lưu lịch sử hàng đợi (giữ lịch sử qua các lần restart)
DATA_DIR=./data

# Mật khẩu bảo vệ app (Basic Auth) — bắt buộc nên đặt khi deploy công khai
APP_PASSWORD=

# API của Voicebox cho tab Giọng nói (app desktop mặc định cổng 17493;
# nếu chạy docker của voicebox thì thường là http://localhost:17600)
VOICEBOX_API_URL=http://localhost:17493

# API của OmniVoice Studio cho tab Giọng nói (app desktop mặc định cổng 3900)
OMNIVOICE_API_URL=http://localhost:3900

# API của VieNeu-TTS — engine giọng TIẾNG VIỆT (server_api.py, cổng 3901)
VIENEU_API_URL=http://localhost:3901

# Cổng của web app
PORT=3000
